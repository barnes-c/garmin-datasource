      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{name=~\"garmin\\\\..*\" && name!~\".*\\\\.day\"}",
          "tableType": "spans",
          "limit": 100,
          "spss": 20
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
