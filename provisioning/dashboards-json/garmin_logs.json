{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "Plugin log volume by level",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({job=\"grafana\"} |= \"plugin.barnesc-garminconnect-datasource\" | logfmt [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      }
    },
    {
      "type": "logs",
      "title": "Plugin errors & warnings",
      "description": "Only error- and warn-level lines from the plugin backend.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"grafana\"} |= \"plugin.barnesc-garminconnect-datasource\" | logfmt | level=~\"error|warn\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "type": "logs",
      "title": "Plugin backend logs",
      "description": "Everything the plugin backend logs (debug level is enabled in the dev container). Filter with the panel search or edit the query.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"grafana\"} |= \"plugin.barnesc-garminconnect-datasource\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["garmin", "dev"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Garmin Datasource Logs",
  "uid": "garmin-logs",
  "version": 1,
  "weekStart": ""
}
