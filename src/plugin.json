{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Garmin Connect",
  "id": "barnescdev-garminconnect-datasource",
  "metrics": true,
  "backend": true,
  "alerting": true,
  "executable": "gpx_garminconnect",
  "info": {
    "description": "Visualize Garmin Connect activities and GPS tracks in Grafana, e.g. on the Geomap panel",
    "author": {
      "name": "Christopher Barnes"
    },
    "keywords": [
      "datasource",
      "garmin",
      "connect",
      "gps",
      "sports",
      "geomap"
    ],
    "logos": {
      "small": "img/logo.png",
      "large": "img/logo.png"
    },
    "links": [
      {
        "name": "GitHub",
        "url": "https://github.com/barnes-c/garmin-datasource"
      },
      {
        "name": "License",
        "url": "https://github.com/barnes-c/garmin-datasource/blob/main/LICENSE"
      },
      {
        "name": "Sponsor",
        "url": "https://github.com/sponsors/barnes-c"
      }
    ],
    "screenshots": [
      {
        "name": "Activity dashboard",
        "path": "img/screenshots/activity.png"
      },
      {
        "name": "Cycling dashboard",
        "path": "img/screenshots/cycling.png"
      },
      {
        "name": "Athlete overview",
        "path": "img/screenshots/athlete-overview.png"
      },
      {
        "name": "Health dashboard",
        "path": "img/screenshots/health.png"
      },
      {
        "name": "Fitness dashboard",
        "path": "img/screenshots/fitness.png"
      },
      {
        "name": "Athlete comparison",
        "path": "img/screenshots/comparison.png"
      }
    ],
    "updated": "%TODAY%",
    "version": "%VERSION%"
  },
  "includes": [
    {
      "type": "dashboard",
      "name": "Garmin Athlete Overview",
      "path": "dashboards/garmin_athlete_overview.json"
    },
    {
      "type": "dashboard",
      "name": "Garmin Activity",
      "path": "dashboards/garmin_activity.json"
    },
    {
      "type": "dashboard",
      "name": "Garmin Health",
      "path": "dashboards/garmin_health.json"
    },
    {
      "type": "dashboard",
      "name": "Garmin Athlete Comparison",
      "path": "dashboards/garmin_athlete_comparison.json"
    },
    {
      "type": "dashboard",
      "name": "Garmin Fitness",
      "path": "dashboards/garmin_fitness.json"
    },
    {
      "type": "dashboard",
      "name": "Garmin Cycling",
      "path": "dashboards/garmin_cycling.json"
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}