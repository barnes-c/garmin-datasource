      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 21 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "queryType": "metric", "metric": "spo2" },
        { "refId": "B", "queryType": "metric", "metric": "respiration" }
