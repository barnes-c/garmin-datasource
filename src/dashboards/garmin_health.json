      "title": "Weight / Body composition",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "body_composition" }],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "^(time|weight|muscle_mass|body_fat)$" } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "spanNulls": true } }, "overrides": [] }
    },
    {
