      "fieldConfig": { "defaults": { "custom": { "spanNulls": true } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Resting HR",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "resting_heart_rate" }],
      "fieldConfig": { "defaults": { "custom": { "spanNulls": true } }, "overrides": [] }
    },
    {
      "type": "timeseries",
