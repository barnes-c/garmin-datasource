{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Resting HR",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "resting_heart_rate" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/^resting_heart_rate$/" },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "HRV",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "hrv" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/^hrv$/" },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "SpO2",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "spo2" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/^spo2$/" },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
