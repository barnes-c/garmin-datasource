      "targets": [{ "refId": "A", "queryType": "metric", "metric": "vo2max" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/^vo2max$/" },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Fitness age",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "fitness_age" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/^fitness_age$/" },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Weight",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "weight" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "/^weight$/" },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "timeseries",
      "title": "Body Battery",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "body_battery" }],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 }, "min": 0, "max": 100 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Sleep",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "sleep" }],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "^(time|deep|light|rem|awake)$" } } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Stress",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
      "targets": [{ "refId": "A", "queryType": "metric", "metric": "stress" }],
      "fieldConfig": { "defaults": { "custom": { "spanNulls": true, "fillOpacity": 20 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "HRV",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
