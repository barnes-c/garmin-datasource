      "targets": [{ "refId": "A", "queryType": "metric", "metric": "hydration" }],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Floors / Intensity minutes",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 21 },
      "datasource": { "type": "barnesc-garminconnect-datasource", "uid": "${datasource}" },
