        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "barAlignment": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "elevation_gain"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
