      },
      "targets": [
        {
          "refId": "A",
          "queryType": "activities"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(time|distance|elevation_gain)$"
            }
