        "view": {
          "id": "fit",
          "zoom": 15,
          "allLayers": true
        },
        "controls": {
          "showZoom": true,
          "mouseWheelZoom": false,
          "showAttribution": true
        },
        "tooltip": {
          "mode": "details"
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "name"
            },
            "properties": [
              {
                "id": "links",
