{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Distance",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^distance$/"
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Avg speed",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 5,
        "y": 0
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "mean"
          ],
          "fields": "/^speed$/"
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Max speed",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 10,
        "y": 0
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "max"
          ],
          "fields": "/^speed$/"
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Avg HR",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "mean"
          ],
          "fields": "/^heartrate$/"
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Max HR",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "max"
          ],
          "fields": "/^heartrate$/"
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "geomap",
      "title": "Route",
      "gridPos": {
        "h": 14,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "options": {
        "view": {
          "id": "fit",
          "allLayers": false,
          "layer": "Fit",
          "zoom": 15,
          "lat": 0,
          "lon": 0
        },
        "basemap": {
          "type": "osm-standard",
          "name": "Basemap",
          "config": {}
        },
        "controls": {
          "showZoom": true,
          "showAttribution": true
        },
        "layers": [
          {
            "type": "route",
            "name": "Route",
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "config": {
              "style": {
                "color": {
                  "field": "heartrate",
                  "fixed": "dark-red"
                },
                "lineWidth": 4,
                "opacity": 1
              }
            },
            "tooltip": true
          },
          {
            "type": "markers",
            "name": "Fit",
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "config": {
              "style": {
                "size": {
                  "fixed": 1
                },
                "color": {
                  "fixed": "transparent"
                },
                "opacity": 0
              },
              "showLegend": false
            },
            "tooltip": false
          }
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Heart rate / Speed",
      "description": "Hovering here moves the crosshair in all other charts. Selecting an activity automatically fits the dashboard time range to it.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity",
          "zoomToActivity": true
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(time|heartrate|speed)$"
            }
          }
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 0,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "speed"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Elevation / Power",
      "description": "Power appears when the activity was recorded with a power meter.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        },
        {
          "refId": "B",
          "queryType": "power",
          "activityId": "$activity",
          "zoomToActivity": true
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 30,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(track )?(time|lat|lon|heartrate|speed|distance)$"
            },
            "properties": [
              {
                "id": "custom.hideFrom",
                "value": {
                  "viz": true,
                  "legend": true,
                  "tooltip": true
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(track )?elevation$"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "elevation"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(power )?power$"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "power"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "barchart",
      "title": "Splits — avg speed",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "splits",
          "activityId": "$activity"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(split|average_speed)$"
            }
          }
        }
      ],
      "options": {
        "xField": "split"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          },
          "noValue": "No laps in this activity"
        },
        "overrides": []
      },
      "description": "Garmin only records splits when the device creates laps (auto-lap or manual lap button)."
    },
    {
      "type": "barchart",
      "title": "Time in HR zones",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "hr_zones",
          "activityId": "$activity"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(zone|time_in_zone)$"
            }
          }
        }
      ],
      "options": {
        "xField": "zone",
        "colorByField": "zone",
        "legend": {
          "showLegend": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "zone"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "text",
                      "value": null
                    },
                    {
                      "color": "blue",
                      "value": 2
                    },
                    {
                      "color": "green",
                      "value": 3
                    },
                    {
                      "color": "orange",
                      "value": 4
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "histogram",
      "title": "Heart rate distribution",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "track",
          "activityId": "$activity"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^heartrate$"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Splits",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "barnescdev-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "splits",
          "activityId": "$activity"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "description": "Garmin only records splits when the device creates laps (auto-lap or manual lap button)."
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": [
    "garmin"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "barnescdev-garminconnect-datasource",
        "current": {},
        "options": [],
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "current": {},
        "datasource": {
          "type": "barnescdev-garminconnect-datasource",
          "uid": "${datasource}"
        },
        "definition": "activities",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "activity",
        "options": [],
        "query": {
          "refId": "variable",
          "activityType": "",
          "limit": 100
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Garmin Activity",
  "uid": "garmin-activity",
  "version": 1,
  "weekStart": ""
}
