            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open activity",
                    "url": "/d/garmin-activity/garmin-activity?var-activity=${__data.fields.activity_id}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "type_id"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "raw_value"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
