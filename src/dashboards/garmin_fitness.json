    {
      "type": "stat",
      "title": "Race predictions (running)",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "barnesc-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metric",
          "metric": "race_predictions"
