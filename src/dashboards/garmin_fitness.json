      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "No prediction"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "5k"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "5K"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "10k"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "10K"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "half_marathon"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Half marathon"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "marathon"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Marathon"
              }
            ]
          }
        ]
      },
      "description": "Garmin's current predicted race times, based on your training."
