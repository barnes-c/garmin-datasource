    {
      "type": "stat",
      "title": "VO2max",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "barnesc-garminconnect-datasource",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metric",
          "metric": "vo2max"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^vo2max$/"
