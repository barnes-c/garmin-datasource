---
extends: default

ignore: |
  dist/
  node_modules/
  .config/

rules:
  braces:
    max-spaces-inside: 1
    level: error
  brackets:
    max-spaces-inside: 1
    level: error
  commas: disable
  comments: disable
  comments-indentation: disable
  # Scaffold-managed workflow files omit the document start marker and are
  # regenerated by create-plugin update, so enforcing it would churn.
  document-start: disable
  indentation:
    spaces: consistent
    indent-sequences: consistent
  line-length: disable
  truthy:
    check-keys: false
